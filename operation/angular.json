{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "operation": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": false
        },
        "@schematics/angular:directive": {
          "standalone": false
        },
        "@schematics/angular:pipe": {
          "standalone": false
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "ngx-build-plus:browser",
          "options": {
            "outputPath": "dist/operation",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public",
                "output": "."
              }
            ],
            "styles": [],
            "scripts": [],
            "extraWebpackConfig": "webpack.config.js",
            "commonChunk": false
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "extraWebpackConfig": "webpack.prod.config.js"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            },
            "esm": {
              "outputHashing": "none",
              "sourceMap": true,
              "optimization": false,
              "extractLicenses": false,
              "namedChunks": true,
              "vendorChunk": true,
              "extraWebpackConfig": "webpack.config.js"
            },
            "sanso_dev": {
              "buildOptimizer": false,
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true,
              "vendorChunk": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.sanso_dev.ts"
                }
              ],
              "extraWebpackConfig": "webpack.config.js"
            },
             "saanso_dev": {
              "buildOptimizer": false,
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true,
              "vendorChunk": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.saanso_dev.ts"
                }
              ],
              "extraWebpackConfig": "webpack.config.js"
            },
             "rqpdev": {
              "buildOptimizer": false,
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true,
              "vendorChunk": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.rqpdev.ts"
                }
              ],
              "extraWebpackConfig": "webpack.config.js"
            },
              "aspen": {
              "buildOptimizer": false,
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true,
              "vendorChunk": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.aspen.ts"
                }
              ],
              "extraWebpackConfig": "webpack.config.js"
            },
              "sales": {
              "buildOptimizer": false,
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false,
              "namedChunks": true,
              "vendorChunk": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.sales.ts"
                }
              ],
              "extraWebpackConfig": "webpack.config.js"
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "ngx-build-plus:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "operation:build:production",
              "extraWebpackConfig": "webpack.prod.config.js"
            },
            "development": {
              "buildTarget": "operation:build:development"
            },
            "esm": {
              "buildTarget": "operation:build:esm",
              "extraWebpackConfig": "webpack.config.js"
            },
            "sanso_dev": {
              "buildTarget": "operation:build:sanso_dev",
              "extraWebpackConfig": "webpack.config.js"
            },
             "saanso_dev": {
              "buildTarget": "operation:build:saanso_dev",
              "extraWebpackConfig": "webpack.config.js"
            },
             "sales": {
              "buildTarget": "operation:build:sales",
              "extraWebpackConfig": "webpack.config.js"
            },
             "aspen": {
              "buildTarget": "operation:build:aspen",
              "extraWebpackConfig": "webpack.config.js"
            },
             "rqpdev": {
              "buildTarget": "operation:build:rqpdev",
              "extraWebpackConfig": "webpack.config.js"
            }
          },
          "defaultConfiguration": "development",
          "options": {
            "port": 4283,
            "publicHost": "http://localhost:4283",
            "extraWebpackConfig": "webpack.config.js"
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": ["zone.js", "zone.js/testing"],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
